{
  "rules": {
    ".read": false,
    ".write": false,
    "plans": {
      "$groupId": {
        ".read": "$groupId.matches(/^[A-Za-z0-9_-]{6,64}$/)",
        ".write": "$groupId.matches(/^[A-Za-z0-9_-]{6,64}$/)"
      }
    },
    "presence": {
      "$groupId": {
        ".read": "$groupId.matches(/^[A-Za-z0-9_-]{6,64}$/)",
        "$clientId": {
          ".write": "$groupId.matches(/^[A-Za-z0-9_-]{6,64}$/) && $clientId.matches(/^[A-Za-z0-9_-]{6,128}$/)"
        }
      }
    }
  }
}
