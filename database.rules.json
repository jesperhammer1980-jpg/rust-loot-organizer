{
  "rules": {
    ".read": false,
    ".write": false,
    "plans": {
      "$groupId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },
    "presence": {
      "$groupId": {
        ".read": "auth != null",
        "$uid": {
          ".write": "auth != null && auth.uid == $uid"
        }
      }
    }
  }
}
